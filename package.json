{
  "name": "crust",
  "displayName": "Crust",
  "description": "Pi Coding Agent Extension",
  "version": "0.0.1",
  "publisher": "crews",
  "icon": "branding/icon.png",
  "repository": "https://github.com/twcrews/crust",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:crust.openChat",
    "onCommand:crust.openChatTerminal",
    "onCommand:crust.openChatDefault",
    "onWebviewPanel:crustChat"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crust.openChat",
        "title": "Crust: Open Chat",
        "icon": {
          "light": "branding/icon-small.svg",
          "dark": "branding/icon-small.svg"
        }
      },
      {
        "command": "crust.openChatTerminal",
        "title": "Crust: Open Chat (Terminal)",
        "icon": {
          "light": "branding/icon-small.svg",
          "dark": "branding/icon-small.svg"
        }
      },
      {
        "command": "crust.openChatDefault",
        "title": "Crust: Open Chat",
        "icon": {
          "light": "branding/icon-small.svg",
          "dark": "branding/icon-small.svg"
        }
      }
    ],
    "keybindings": [
      {
        "command": "crust.openChat",
        "key": "cmd+ctrl+escape",
        "mac": "cmd+ctrl+escape"
      },
      {
        "command": "crust.openChatTerminal",
        "key": "ctrl+alt+cmd+escape",
        "mac": "ctrl+alt+cmd+escape"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "crust.openChatDefault",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "crust.openChatDefault",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Crust",
      "properties": {
        "crust.markdown.allowRawHtml": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Allow raw HTML in chat Markdown. When disabled, HTML is shown as text. When enabled, HTML is sanitized before rendering."
        },
        "crust.pi.commandPath": {
          "type": "string",
          "default": "pi",
          "markdownDescription": "Command or absolute path used to start the Pi Coding Agent RPC process."
        },
        "crust.chat.includeIdeContextByDefault": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable current editor file/selection context for new prompts by default. Disabled by default to avoid sending IDE context unless explicitly enabled."
        },
        "crust.chat.useTerminalViewByDefault": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When enabled, clicking the Crust editor toolbar button opens a VS Code terminal editor running Pi's native TUI instead of the Crust webview."
        },
        "crust.chat.lockEditorGroupOnOpen": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Lock the Crust chat editor group after opening the chat beside the current editor."
        },
        "crust.pi.defaultModel": {
          "type": "string",
          "default": "",
          "markdownDescription": "Preferred model key to select when Crust starts, using the format shown in the model picker, for example `provider:model-id`. Leave empty to use Pi's current model."
        },
        "crust.session.restoreOnReload": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Restore serialized Crust chat tabs to their previous Pi session after a VS Code window reload. When disabled, restored tabs start from Pi's current session instead."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && npm run check-webview && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && npm run check-webview && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "check-webview": "find media/chatWebview -name '*.js' -print0 | xargs -0 -n1 node --check",
    "lint": "eslint src",
    "test": "npm-run-all test:min-vscode test:current-vscode",
    "test:min-vscode": "vscode-test --code-version 1.74.0",
    "test:current-vscode": "vscode-test",
    "test:quick": "vscode-test --code-version 1.74.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.8.0",
    "@types/vscode": "1.74.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dompurify": "^3.4.5",
    "markdown-it": "^14.1.1"
  }
}
